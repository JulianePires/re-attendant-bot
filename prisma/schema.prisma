// Documentação: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // DATABASE_URL aponta para o pooler do Supabase (usado em runtime pela aplicação)
  url       = env("DATABASE_URL")
  // DIRECT_URL ignora o pooler e conecta diretamente ao banco (necessário para executar migrações)
  directUrl = env("DIRECT_URL")
}

// ================================================================
// TABELAS DO BETTERAUTH
// Estas tabelas são gerenciadas pelo framework. Os nomes de campo
// seguem a convenção camelCase do Prisma, mapeados para snake_case
// no banco via @@map e @map.
// ================================================================

model User {
  id            String    @id
  name          String
  email         String?   @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  // Campos adicionados pelo plugin de Admin do BetterAuth para RBAC.
  // Role estritamente para profissionais: 'admin' | 'profissional'
  // Pacientes NÃO são mais usuários do sistema
  role      String?   @default("profissional")
  banned    Boolean?
  banReason String?
  banExpires DateTime?

  // Campos customizados da clínica (apenas para profissionais)
  cpf          String?   @unique
  ultimoAcesso DateTime?

  // Relações (apenas com entidades administrativas)
  sessions     Session[]
  accounts     Account[]
  notificacoes Notificacao[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ================================================================
// TABELAS DE NEGÓCIO
// ================================================================

enum TipoNotificacao {
  URGENTE
  NORMAL
}

model Notificacao {
  id        String   @id @default(cuid())
  titulo    String
  mensagem  String
  tipo      TipoNotificacao @default(NORMAL)
  lida      Boolean  @default(false)
  criadoEm  DateTime @default(now())

  usuarioId String
  usuario   User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("notificacao")
}

model Atendimento {
  id         String   @id @default(cuid())
  
  // Nome do paciente armazenado diretamente (sem relação com User)
  nomePaciente String

  // Discriminadores de tipo: 'normal' | 'urgente'
  tipoChamada String @default("normal")
  // Máquina de estados simples: 'aguardando' | 'finalizado'
  status      String @default("aguardando")

  criadoEm    DateTime  @default(now())
  finalizadoEm DateTime?
  arquivadoTurno Boolean @default(false)

  // Índice composto para queries de fila (status + criadoEm é o padrão de ordenação)
  @@index([status, criadoEm])
  @@map("atendimento")
}
